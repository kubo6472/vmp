VMP_ENV=staging

# Shared
API_URL=http://localhost:8787
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
R2_BASE_URL=https://example-r2-domain/videos

# API secrets (set real values in CI / Wrangler secrets for deployed envs)
BREVO_API_KEY=replace_with_brevo_key
JWT_SECRET=replace_with_32_plus_characters
RSS_SECRET=replace_with_32_plus_characters
STRIPE_SECRET_KEY=replace_with_stripe_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret
TOTP_ENCRYPTION_KEY=replace_with_32_plus_characters
VAPID_PUBLIC_KEY=replace_with_vapid_public
VAPID_PRIVATE_KEY=replace_with_vapid_private

# External API key used by /api/pills/update.
# Runtime first checks env.PILLS_API_KEY and falls back to admin_settings.pills_api_key.
PILLS_API_KEY=replace_with_pills_api_key
